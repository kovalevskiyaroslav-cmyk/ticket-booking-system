<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
           http://www.liquibase.org/xml/ns/dbchangelog
           http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="venues" author="Yaroslav">
        <insert tableName="venues">
            <column name="id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="name" value="Main Hall"/>
            <column name="address" value="123 Main St"/>
        </insert>
        <insert tableName="venues">
            <column name="id" value="22222222-2222-2222-2222-222222222222"/>
            <column name="name" value="Concert Arena"/>
            <column name="address" value="456 Arena Blvd"/>
            <!-- city removed - not in entity -->
        </insert>
    </changeSet>

    <!-- 2. Users -->
    <changeSet id="users" author="Yaroslav">
        <insert tableName="users">
            <column name="id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"/>
            <column name="name" value="Alice"/>
            <column name="email" value="alice@example.com"/>
            <column name="phone" value="1234567890"/>
            <!-- active removed - not in entity -->
        </insert>
        <insert tableName="users">
            <column name="id" value="bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb"/>
            <column name="name" value="Bob"/>
            <column name="email" value="bob@example.com"/>
            <column name="phone" value="0987654321"/>
            <!-- active removed - not in entity -->
        </insert>
    </changeSet>

    <!-- 3. Payments -->
    <changeSet id="payments" author="Yaroslav">
        <insert tableName="payments">
            <column name="id" value="dddddddd-dddd-dddd-dddd-dddddddddddd"/>
            <column name="status" value="PENDING"/>
            <column name="amount" valueNumeric="50.00"/>  <!-- Fixed: payment_amount → amount -->
            <!-- timestamp removed - not in entity -->
        </insert>
        <insert tableName="payments">
            <column name="id" value="ffffffff-ffff-ffff-ffff-ffffffffffff"/>
            <column name="status" value="PENDING"/>
            <column name="amount" valueNumeric="55.00"/>  <!-- Fixed: payment_amount → amount -->
            <!-- timestamp removed - not in entity -->
        </insert>
    </changeSet>

    <!-- 4. Orders -->
    <changeSet id="orders" author="Yaroslav">
        <insert tableName="orders">
            <column name="id" value="cccccccc-cccc-cccc-cccc-cccccccccccc"/>
            <column name="completed_at" valueDate="2026-03-01T12:00:00"/>  <!-- Fixed: date_time → completed_at -->
            <column name="status" value="CREATED"/>
            <column name="total_price" valueNumeric="50.00"/>
            <column name="deleted" valueBoolean="false"/>
            <column name="user_id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"/>
            <column name="payment_id" value="dddddddd-dddd-dddd-dddd-dddddddddddd"/>
        </insert>
        <insert tableName="orders">
            <column name="id" value="eeeeeeee-eeee-eeee-eeee-eeeeeeeeeeee"/>
            <column name="completed_at" valueDate="2026-03-01T12:05:00"/>  <!-- Fixed: date_time → completed_at -->
            <column name="status" value="CREATED"/>
            <column name="total_price" valueNumeric="55.00"/>
            <column name="deleted" valueBoolean="false"/>
            <column name="user_id" value="bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb"/>
            <column name="payment_id" value="ffffffff-ffff-ffff-ffff-ffffffffffff"/>
        </insert>
    </changeSet>

    <!-- 5. Events -->
    <changeSet id="events" author="Yaroslav">
        <insert tableName="events">
            <column name="id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa01"/>
            <column name="name" value="Rock Concert"/>
            <column name="description" value="Best rock concert"/>
            <column name="date_time" valueDate="2026-03-10T20:00:00"/>
            <column name="venue_id" value="11111111-1111-1111-1111-111111111111"/>
        </insert>
        <insert tableName="events">
            <column name="id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa02"/>
            <column name="name" value="Classical Night"/>
            <column name="description" value="Evening of classical music"/>
            <column name="date_time" valueDate="2026-03-11T19:00:00"/>
            <column name="venue_id" value="22222222-2222-2222-2222-222222222222"/>
        </insert>
    </changeSet>

    <!-- 6. Seats (MUST be before tickets) -->
    <changeSet id="seats" author="Yaroslav">
        <insert tableName="seats">
            <column name="id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa11"/>
            <column name="number" valueNumeric="1"/>  <!-- Fixed: seat_num → number -->
            <column name="section" valueNumeric="1"/>
            <column name="price" valueNumeric="50.00"/>
            <column name="venue_id" value="11111111-1111-1111-1111-111111111111"/>
            <!-- ticket_id removed - not in entity -->
        </insert>
        <insert tableName="seats">
            <column name="id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa12"/>
            <column name="number" valueNumeric="2"/>  <!-- Fixed: seat_num → number -->
            <column name="section" valueNumeric="1"/>
            <column name="price" valueNumeric="55.00"/>
            <column name="venue_id" value="22222222-2222-2222-2222-222222222222"/>
            <!-- ticket_id removed -->
        </insert>
        <insert tableName="seats">
            <column name="id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa13"/>
            <column name="number" valueNumeric="3"/>  <!-- Fixed: seat_num → number -->
            <column name="section" valueNumeric="1"/>
            <column name="price" valueNumeric="55.00"/>
            <column name="venue_id" value="22222222-2222-2222-2222-222222222222"/>
            <!-- ticket_id removed -->
        </insert>
    </changeSet>

    <!-- 7. Tickets (NOW with seat_id) -->
    <changeSet id="tickets" author="Yaroslav">
        <insert tableName="tickets">
            <column name="id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="seat_id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa11"/>  <!-- Added -->
            <column name="price" valueNumeric="50.00"/>
            <column name="event_id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa01"/>
            <column name="order_id" value="cccccccc-cccc-cccc-cccc-cccccccccccc"/>
            <!-- purchase_date_time removed - not in entity -->
        </insert>
        <insert tableName="tickets">
            <column name="id" value="22222222-2222-2222-2222-222222222222"/>
            <column name="seat_id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa12"/>  <!-- Added -->
            <column name="price" valueNumeric="55.00"/>
            <column name="event_id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa02"/>
            <column name="order_id" value="eeeeeeee-eeee-eeee-eeee-eeeeeeeeeeee"/>
            <!-- purchase_date_time removed -->
        </insert>
    </changeSet>

    <!-- 8. User Favorite Events -->
    <changeSet id="user-favorite-events" author="Yaroslav">
        <insert tableName="user_favorite_events">
            <column name="user_id" value="aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"/>
